{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "debugpy",
            "request": "launch",
            "django": true,
            "program": "${workspaceFolder}/.vscode/debug.py",
            "args": [
                "${input:pickTasks}"
            ],
            "justMyCode": true,
            "preLaunchTask": "set-dev-fkq-env",
            "env": {
                "DJANGO_ENVIRONMENT": "dev_fkq",
            },
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        },
        {
            "name": "Django: 启动服务",
            "type": "debugpy",
            "request": "launch",
            "args": [
                "runserver",
                "0.0.0.0:8011"
            ],
            "django": true,
            "program": "${workspaceFolder}/manage.py",
            "justMyCode": true,
            "preLaunchTask": "set-dev-fkq-env",
            "env": {
                "DJANGO_ENVIRONMENT": "dev_fkq"
            },
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "type": "pickString",
            "id": "pickTasks",
            "description": "选择操作脚本方式",
            "options": [
                "继续执行",
                "其他脚本"
            ]
        }
    ]
}